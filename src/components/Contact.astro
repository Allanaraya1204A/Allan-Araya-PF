---

---

<section id="contacto" class="relative py-16 md:py-32 px-6 md:px-12 bg-ink overflow-hidden">
  <!-- big bg text -->
  <div
    class="absolute right-[-2rem] bottom-[-3rem] pointer-events-none select-none font-syne font-extrabold"
    style="font-size:clamp(8rem,16vw,12rem); color:transparent; -webkit-text-stroke:1px rgba(0, 109, 210, 0.35)"
  >
    CONTACT
  </div>

  <div class="sec-label">
    <span class="mono-tag">&lt;</span>04<span class="mono-tag">/&gt;</span>
  </div>

  <div
    class="relative z-[1] grid gap-20 items-start"
    style="grid-template-columns:1fr 1fr"
  >
    <!-- LEFT -->
    <div class="reveal">
      <h2
        class="font-syne font-extrabold leading-[.9] mb-10 md:mb-16 
           text-3xl sm:text-4xl md:text-6xl lg:text-7xl"
      >
        ¿Construimos<br /><span class="text-gold">algo juntos?</span>
      </h2>
      <p
        class="font-syne text-sm leading-loose mb-10 max-w-sm"
        style="color:rgba(232,223,200,.45)"
      >
        Abierto a oportunidades, colaboraciones y proyectos.
      </p>

      <!--  terminal -->
      <div
        style="border:1px solid rgba(255,195,0,.14); background:#0d1117; overflow:hidden"
      >
        <div
          class="flex items-center gap-2 px-4 py-[7px]"
          style="background:#161b22; border-bottom:1px solid rgba(255,255,255,.06)"
        >
          <span
            class="w-[11px] h-[11px] rounded-full"
            style="background:#ff5f57"></span>
          <span class="w-[11px] h-[11px] rounded-full bg-gold"></span>
          <span
            class="w-[11px] h-[11px] rounded-full"
            style="background:#28c840"></span>
          <span
            class="font-mono ml-2"
            style="font-size:.68rem; color:rgba(255,255,255,.28)"
            >contact.sh</span
          >
        </div>
        <div class="flex flex-col gap-2 px-4 py-4">
          <div class="font-mono" style="font-size:.75rem; line-height:1.6">
            <span class="text-gold mr-2">$</span>
            <span style="color:#d2a8ff">echo</span>
            <span style="color:#a5d6ff">
              "Hola Allan, tengo un proyecto..."</span
            >
          </div>
          <div
            class="font-mono pl-4"
            style="font-size:.75rem; color:rgba(255,255,255,.32)"
          >
            → Mensaje recibido.
          </div>
          <div class="font-mono" style="font-size:.75rem">
            <span class="text-gold mr-2">$</span>
            <span
              class="text-gold"
              style="animation:blink .8s step-end infinite">▋</span
            >
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT: links -->
    <div class="reveal flex flex-col">
      {
        [
          {
            href: "/Allan Araya Rodriguez.pdf",
            label: "CV",
            value: "Descargar curriculum",
            icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12" /><path d="M7 10l5 5 5-5" /><path d="M5 21h14" /></svg>`,
          },
          {
            href: "https://linkedin.com/in/allanmauricioaraya",
            label: "LinkedIn",
            value: "linkedin.com/in/allanmauricioaraya",
            icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
          },
          {
            href: "https://github.com/Allanaraya1204A",
            label: "GitHub",
            value: "github.com/Allanaraya1204A",
            icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.49.5.09.68-.22.68-.48v-1.69c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.89 1.52 2.34 1.08 2.91.83.09-.65.35-1.08.63-1.33-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.56 9.56 0 0112 6.8c.85 0 1.71.11 2.51.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10.01 10.01 0 0022 12c0-5.52-4.48-10-10-10z"/></svg>`,
          },
        ].map((item, i) => (
          <a
            href={item.href}
            target={item.href.startsWith("http") ? "_blank" : undefined}
            download={
              item.href.endsWith(".pdf")
                ? "Allan_Mauricio_Araya_Rodriguez_CV.pdf"
                : undefined
            }
            class="contact-item flex items-center gap-5 py-5 transition-all duration-300"
          >
            <div
              class="flex items-center justify-center w-10 h-10 shrink-0 text-gold"
              style="background:rgba(255,195,0,.06); border:1px solid rgba(255,195,0,.17); clip-path:polygon(0 0,calc(100% - 7px) 0,100% 7px,100% 100%,7px 100%,0 calc(100% - 7px))"
              set:html={item.icon}
            />
            <div class="flex-1">
              <span
                class="block font-mono uppercase tracking-widest mb-1"
                style="font-size:.6rem; color:rgba(255,195,0,.45)"
              >
                {item.label}
              </span>
              <span
                class="font-syne text-sm"
                style="color:rgba(232,223,200,.45)"
              >
                {item.value}
              </span>
            </div>
            <span
              class="contact-arrow font-mono transition-all duration-300"
              style="color:rgba(255,195,0,.28)"
            >
              →
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .contact-item:hover {
    padding-left: 0.75rem;
  }
  .contact-item:hover .contact-arrow {
    transform: translateX(5px);
    color: #ffc300;
  }
  .contact-item:hover span:last-of-type {
    color: #e8dfc8;
  }
  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
  @media (max-width: 900px) {
    section > div:last-child {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<script>
  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add("visible");
      });
    },
    { threshold: 0.1 },
  );
  document
    .querySelectorAll("#contacto .reveal")
    .forEach((el) => obs.observe(el));
</script>
